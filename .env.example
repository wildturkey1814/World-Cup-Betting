# Copy to .env and fill in keys for local data fetching.
# The static site works without keys using bundled data.json.

# football-data.org — live scores (free tier)
FOOTBALL_DATA_KEY=

# OddsPapi — sportsbook odds (premium; optional locally)
ODDSPAPI_KEY=
ODDSPAPI_KEY2=
ODDSPAPI_KEY3=
ODDSPAPI_KEY4=
ODDSPAPI_KEY5=
ODDSPAPI_KEY6=
FORCE_FETCH=0

# Kalshi — prediction market orderbooks (optional)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=

# API-Football — live client features in index.html (optional)
API_FOOTBALL_KEY=
API_FOOTBALL_KEY2=

# Zafronix — alternate live data source (optional)
ZAFRONIX_API_KEY=
ZAFRONIX_API_KEY2=
